{
  "name": "@kagura/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run codegen && vite build",
    "codegen": "panda codegen",
    "dev": "vite --host 127.0.0.1",
    "dev:mock": "KAGURA_WEB_MOCK_API=true vite --host 127.0.0.1 --open /reviews/mock-review",
    "prepare": "npm run codegen",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "npm run codegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@pierre/diffs": "^1.1.20",
    "@pierre/trees": "1.0.0-beta.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^0.474.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-resizable-panels": "^3.0.2",
    "shiki": "^3.0.0",
    "typescript": "^6.0.2",
    "vite": "8.0.10",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "code-inspector-plugin": "^1.5.1"
  }
}
